BEGIN
    DECLARE v_ID INT DEFAULT NULL;
    DECLARE v_Equipa INT DEFAULT NULL;

    -- Busca o ID e Equipa do utilizador
    SELECT IDUtilizador, Equipa
      INTO v_ID, v_Equipa
    FROM utilizador
    WHERE Email = p_Email
    LIMIT 1;

    IF v_ID IS NOT NULL THEN
        -- Retorna os dados para a aplicação
        SELECT 'Sucesso: Utilizador identificado' AS Mensagem,
               v_ID AS IDUtilizador,
               v_Equipa AS Equipa;
    ELSE
        -- Gera erro se o email não existir
        SIGNAL SQLSTATE '45000'
        SET MESSAGE_TEXT = 'Erro: Utilizador não encontrado no sistema.';
    END IF;
END
